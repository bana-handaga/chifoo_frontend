# ============================================================
#  PTMA Monitor — Frontend Proxy Server
#  Salin file ini: cp .env.example .env
#  Digunakan oleh proxy-serve.js saat menjalankan server Node.
# ============================================================

# URL Django backend (tanpa trailing slash)
# Jika Django berjalan di server yang sama pada port 8001:
API_TARGET=http://127.0.0.1:8001

# Port server frontend ini berjalan
PORT=4200
